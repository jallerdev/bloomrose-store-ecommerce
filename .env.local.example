# ─── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Usar el Session Pooler de Supabase (puerto 6543), no 5432
DATABASE_URL=

# ─── Sitio ──────────────────────────────────────────────────────
# URL pública del sitio. Usada para construir el redirect-url de Wompi,
# los enlaces de los emails, el sitemap y los OpenGraph tags.
# En local: http://localhost:3000 (o la URL HTTPS del túnel ngrok/cloudflared
# si vas a probar Wompi).
# En producción: https://bloomroseaccesorios.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Wompi (pasarela de pago) ───────────────────────────────────
# Obtener en: https://comercios.wompi.co/
# Para pruebas usa las llaves "Sandbox" (pub_test_*, prv_test_*).
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
# Opcional: override del API base. Para sandbox: https://sandbox.wompi.co/v1
# WOMPI_API_URL=https://production.wompi.co/v1

# ─── Coordinadora (transportadora) ──────────────────────────────
# Requiere convenio comercial. Si está vacío, el envío usa tarifa
# plana provisional definida en lib/shipping/index.ts.
COORDINADORA_API_KEY=
COORDINADORA_NIT=
COORDINADORA_ID_CLIENTE=
COORDINADORA_ORIGIN_CITY=Bogota
COORDINADORA_ORIGIN_DEPARTMENT=Cundinamarca
# COORDINADORA_API_URL=https://api.coordinadora.com/api/v2

# ─── Resend (emails transaccionales) ────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=
# Si aún no has verificado dominio puedes usar onboarding@resend.dev
EMAIL_FROM=Bloomrose <onboarding@resend.dev>
